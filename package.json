{
  "name": "home-dashboard",
  "version": "1.0.0",
  "description": "Home dashboard for seeed studio",
  "type": "module",
  "main": "dist/server.js",
  "author": "Oscar Sims and Kyle Turman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oscarcs/home-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/oscarcs/home-dashboard/issues"
  },
  "homepage": "https://github.com/oscarcs/home-dashboard#readme",
  "keywords": [
    "dashboard",
    "e-paper",
    "e-ink",
    "weather",
    "iot",
    "home-automation",
    "esp32",
    "arduino"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "dev": "port=$(grep '^PORT=' .env | cut -d '=' -f2); next dev -p ${port:-7272}",
    "build": "next build && mkdir -p .next/standalone/.next && rm -rf .next/standalone/.next/static .next/standalone/public && cp -R .next/static .next/standalone/.next/static && cp -R public .next/standalone/public",
    "start": "port=$(grep '^PORT=' .env | cut -d '=' -f2); DATA_DIR=${DATA_DIR:-$(pwd)/data} PORT=${port:-7272} node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/postcss": "^4.2.4",
    "axios": "^1.15.2",
    "dotenv": "^17.4.2",
    "next": "^16.2.4",
    "puppeteer": "^24.42.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "yahoo-finance2": "^3.14.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
