# ===== Location Configuration =====
# Primary location (recommended format: "City, State/Region, Country")
# Use this for international locations and metric support.
MAIN_LOCATION="Sydney, NSW, AU"

# ===== Weather Configuration =====
# Google Maps Platform API Key
GOOGLE_MAPS_API_KEY=

# ===== Server Configuration =====
# Port for the Express server (default: 7272)
PORT=7272

# Data directory path (default: ./data)
DATA_DIR=./data

# ===== E-Paper Display Configuration =====
# Display dimensions in pixels (default: 800x480 for 7.5" display)
DISPLAY_WIDTH=800
DISPLAY_HEIGHT=480

# ===== LLM Configuration (Optional) =====
# codex uses the local `codex exec` CLI and your Codex/ChatGPT plan.
# gemini uses the Gemini API key below. none disables AI-generated summaries.
LLM_PROVIDER=codex

# Optional Codex CLI overrides.
CODEX_BIN=codex
CODEX_LLM_MODEL=gpt-5.4-mini
CODEX_LLM_REASONING_EFFORT=low
CODEX_LLM_TIMEOUT_MS=90000

# Gemini API fallback, used only when LLM_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
